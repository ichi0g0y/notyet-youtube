{
  "manifest_version": 3,
  "name": "fadee",
  "version": "0.1.2",
  "description": "Hide watched videos on YouTube channel pages.",
  "permissions": ["storage", "offscreen"],
  "host_permissions": ["https://www.youtube.com/*"],
  "icons": {
    "16": "icons/neutral/16.png",
    "32": "icons/neutral/32.png",
    "48": "icons/neutral/48.png",
    "128": "icons/neutral/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/light/16.png",
      "32": "icons/light/32.png",
      "48": "icons/light/48.png",
      "128": "icons/light/128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
